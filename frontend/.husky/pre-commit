#!/bin/sh
# Run pre-commit checks from git root
echo "=== Running Pre-Commit Lint & Typecheck Checks ==="

cd frontend

# Run linting
pnpm lint
LINT_STATUS=$?

if [ $LINT_STATUS -ne 0 ]; then
  echo "ESLint failed. Commit aborted............"
  exit 1
fi

# Run type checking
pnpm typecheck
TSC_STATUS=$?

if [ $TSC_STATUS -ne 0 ]; then
  echo "TypeScript type checking failed. Commit aborted.........."
  exit 1
fi

echo "All checks passed successfully!"
exit 0
